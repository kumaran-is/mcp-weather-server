# Production Environment Configuration
# Copy this file to .env.production and update with production values
# NEVER commit .env.production to version control

# ===========================================
# API Configuration
# ===========================================
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
GEOCODING_API_URL=https://geocoding-api.open-meteo.com/v1

# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=production
MCP_TRANSPORT=http
MCP_HTTP_PORT=8080
MCP_PROTOCOL_VERSION=2025-06-18

# ===========================================
# Security Configuration (REQUIRED for production)
# ===========================================
# Replace with your actual allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=warn
LOG_API_REQUESTS=false
DEBUG=false

# ===========================================
# Performance Settings (Production optimized)
# ===========================================
API_TIMEOUT=10000
HTTP_TIMEOUT=60000
API_RETRIES=3
API_RETRY_DELAY=2000

# ===========================================
# Connection Pool (Production scale)
# ===========================================
POOL_CONNECTIONS=100
POOL_PIPELINING=10
KEEP_ALIVE_TIMEOUT=120000
KEEP_ALIVE_MAX_TIMEOUT=600000
CONNECT_TIMEOUT=15000
BODY_TIMEOUT=300000
HEADERS_TIMEOUT=30000
REQUEST_TIMEOUT=90000

# ===========================================
# Circuit Breaker (Production thresholds)
# ===========================================
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_TIMEOUT=60000
CIRCUIT_BREAKER_HEALTH_CHECK=10000

# ===========================================
# Retry Strategy (Production settings)
# ===========================================
MAX_RETRIES=5
BASE_RETRY_DELAY=2000
MAX_RETRY_DELAY=30000
JITTER_FACTOR=0.2

# ===========================================
# Bulkhead Configuration (Production scale)
# ===========================================
BULKHEAD_MAX_CONCURRENT=50
BULKHEAD_MAX_QUEUE_SIZE=100
BULKHEAD_QUEUE_TIMEOUT=60000

# ===========================================
# Rate Limiting (Production limits)
# ===========================================
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BURST=50
RATE_LIMIT_SLIDING=true
MAX_CONCURRENT_REQUESTS=200
RATE_LIMIT_PER_SECOND=20

# ===========================================
# Session Management (Production scale)
# ===========================================
SESSION_TIMEOUT=3600000  # 1 hour
MAX_SESSIONS=1000

# ===========================================
# Docker & Deployment
# ===========================================
CONTAINER_PORT=8080
HEALTH_CHECK_PATH=/health

# ===========================================
# Optional: Redis Configuration (for session persistence)
# ===========================================
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
# REDIS_KEY_PREFIX=mcp:weather:

# ===========================================
# Optional: Monitoring & Metrics
# ===========================================
# METRICS_ENABLED=true
# METRICS_INTERVAL=60000
# PROMETHEUS_PORT=9090

# ===========================================
# Optional: SSL/TLS Configuration
# ===========================================
# HTTPS_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CA_PATH=/path/to/ca.pem

# ===========================================
# Optional: External Services
# ===========================================
# SENTRY_DSN=https://your-sentry-dsn
# NEW_RELIC_LICENSE_KEY=your-new-relic-key
# DATADOG_API_KEY=your-datadog-key

# ===========================================
# Production Notes:
# ===========================================
# 1. Always use HTTPS in production
# 2. Set specific ALLOWED_ORIGINS (never use *)
# 3. Use environment-specific secrets management
# 4. Monitor resource usage and adjust limits accordingly
# 5. Consider using a CDN for static assets
# 6. Implement proper backup strategies for persistent data
# 7. Use container orchestration (Kubernetes, ECS, etc.) for scale
# 8. Set up monitoring and alerting
# 9. Implement log aggregation (ELK, Datadog, etc.)
# 10. Regular security audits and dependency updates