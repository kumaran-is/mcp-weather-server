{
  "name": "mcp-weather-server",
  "version": "1.0.0",
  "description": "MCP server with Open-Meteo weather API integration supporting stdio and Streamable HTTP",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "stdio": "MCP_TRANSPORT=stdio tsx src/server.ts",
    "http": "MCP_TRANSPORT=http tsx src/server.ts",
    "client": "tsx src/client-example.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --fix --no-warn-ignored"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "dotenv": "~16.4.1",
    "node-fetch": "~3.3.2",
    "pino": "~8.15.0",
    "uuid": "~9.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "~29.5.5",
    "@types/long": "~4.0.2",
    "@types/node": "~22.0.0",
    "@types/uuid": "~9.0.7",
    "@typescript-eslint/eslint-plugin": "~8.43.0",
    "@typescript-eslint/parser": "~8.43.0",
    "eslint": "~9.35.0",
    "jest": "~29.7.0",
    "pino-pretty": "~13.1.1",
    "ts-jest": "~29.1.1",
    "tsx": "~4.7.0",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "weather",
    "open-meteo",
    "typescript",
    "nodejs"
  ],
  "author": "MCP Weather Server Team",
  "license": "MIT"
}
