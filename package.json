{
  "name": "mcp-weather-server",
  "version": "1.0.0",
  "description": "MCP server with Open-Meteo weather API integration supporting stdio and Streamable HTTP",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "stdio": "MCP_TRANSPORT=stdio tsx src/server.ts",
    "http": "MCP_TRANSPORT=http tsx src/server.ts",
    "client": "tsx src/client-example.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.1",
    "pino": "^8.15.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.8.0",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.5",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": ["mcp", "weather", "open-meteo", "typescript", "nodejs"],
  "author": "MCP Weather Server Team",
  "license": "MIT"
}
