{
  "name": "mcp-weather-server",
  "version": "2.6.0",
  "description": "Modern MCP server with Open-Meteo weather API integration using latest SDK patterns, supporting stdio and HTTP transports",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "stdio": "MCP_TRANSPORT=stdio tsx src/server.ts",
    "http": "MCP_TRANSPORT=http tsx src/server.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "NODE_OPTIONS='--max-old-space-size=4096' vitest run --coverage --reporter=verbose",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --fix --no-warn-ignored"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.17.5",
    "@opentelemetry/api": "~1.9.0",
    "dompurify": "~3.2.0",
    "dotenv": "~17.2.2",
    "fastify": "~5.6.0",
    "jsdom": "~25.0.1",
    "lru-cache": "~11.2.1",
    "p-queue": "~8.1.1",
    "pino": "~9.9.4",
    "rate-limiter-flexible": "~7.3.1",
    "undici": "~7.16.0",
    "uuid": "~13.0.0",
    "zod": "~4.0.1"
  },
  "devDependencies": {
    "@types/dompurify": "~3.0.5",
    "@types/jsdom": "~21.1.7",
    "@types/long": "~5.0.0",
    "@types/lru-cache": "~7.10.9",
    "@types/node": "~22.0.0",
    "@types/uuid": "~10.0.0",
    "@typescript-eslint/eslint-plugin": "~8.43.0",
    "@typescript-eslint/parser": "~8.43.0",
    "@vitest/coverage-v8": "~3.2.4",
    "eslint": "~9.35.0",
    "pino-pretty": "~13.1.1",
    "tsx": "~4.20.5",
    "typescript": "~5.9.2",
    "vitest": "~3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "weather",
    "open-meteo",
    "typescript",
    "nodejs"
  ],
  "author": "MCP Weather Server Team",
  "license": "MIT"
}
