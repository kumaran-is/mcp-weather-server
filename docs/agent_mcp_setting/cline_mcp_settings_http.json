{
  "mcpServers": {
    "weather": {
      "autoApprove": [
        "get_current_weather",
        "get_weather_forecast",
        "retrieve_weather_context"
      ],
      "disabled": false,
      "timeout": 30,
      "type": "streamableHttp",
      "url": "http://localhost:8080/mcp",
      "headers": {
        "Content-Type": "application/json",
        "MCP-Protocol-Version": "2025-06-18",
        "Accept": "application/json, text/event-stream"
      }
    }
  }
}
