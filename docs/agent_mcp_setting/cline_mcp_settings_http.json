{
  "mcpServers": {
    "weather-http": {
      "url": "http://localhost:8080/mcp",
      "type": "sse",
      "transport": {
        "type": "sse",
        "baseUrl": "http://localhost:8080",
        "endpoint": "/mcp"
      },
      "disabled": false,
      "autoApprove": [
        "get_current_weather",
        "get_weather_forecast",
        "retrieve_weather_context"
      ],
      "alwaysAllow": [
        "tools/list"
      ],
      "timeout": 30000
    }
  }
}