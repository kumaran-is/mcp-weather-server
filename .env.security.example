# Security Configuration for MCP Weather Server
# Copy this file to .env.security and customize for your environment

# =============================================================================
# SECURITY MONITORING
# =============================================================================

# Enable/disable security monitoring
SECURITY_MONITORING_ENABLED=true

# Enable/disable audit logging
AUDIT_LOGGING_ENABLED=true

# Audit log destinations
AUDIT_LOG_FILE=true
AUDIT_LOG_SYSLOG=false
AUDIT_LOG_WEBHOOK_URL=

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================

# Global rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_LIMIT=20
RATE_LIMIT_BLOCK_DURATION=300000

# Weather-specific rate limiting
WEATHER_RATE_LIMIT_PER_MINUTE=60
GEOCODING_RATE_LIMIT_PER_MINUTE=30

# =============================================================================
# AUDIT CONFIGURATION
# =============================================================================

# Audit event retention
AUDIT_RETENTION_DAYS=90
AUDIT_MAX_EVENTS=10000
AUDIT_MINIMUM_SEVERITY=low

# Audit categories to log (comma-separated)
AUDIT_ENABLED_CATEGORIES=authentication,authorization,data_access,security,api_usage,configuration

# =============================================================================
# BRUTE FORCE PROTECTION
# =============================================================================

# Brute force detection settings
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_TIME_WINDOW=300000
BRUTE_FORCE_BLOCK_DURATION=900000

# =============================================================================
# THREAT DETECTION
# =============================================================================

# Enable specific threat detection types
THREAT_DETECTION_SQL_INJECTION=true
THREAT_DETECTION_XSS=true
THREAT_DETECTION_PATH_TRAVERSAL=true
THREAT_DETECTION_COMMAND_INJECTION=true

# =============================================================================
# IP BLOCKING CONFIGURATION
# =============================================================================

# Enable automatic IP blocking
IP_BLOCKING_ENABLED=true
IP_BLOCKING_AUTO_BLOCK=true

# Whitelisted IPs (comma-separated)
IP_WHITELIST=127.0.0.1,::1

# Blacklisted IPs (comma-separated)
IP_BLACKLIST=

# =============================================================================
# DATA PROTECTION
# =============================================================================

# Enable sensitive data masking in audit logs
SENSITIVE_DATA_MASKING_ENABLED=true
MASK_API_KEYS=true
MASK_PASSWORDS=true
MASK_PERSONAL_DATA=true

# Custom mask patterns (comma-separated regex patterns)
CUSTOM_MASK_PATTERNS=secret,token,key

# =============================================================================
# ALERTING CONFIGURATION
# =============================================================================

# Enable real-time alerting
SECURITY_ALERTING_ENABLED=true
CRITICAL_THREAT_THRESHOLD=10

# Alert destinations
ALERT_WEBHOOK_URL=
ALERT_EMAIL_RECIPIENTS=

# =============================================================================
# COMPLIANCE SETTINGS
# =============================================================================

# Enable compliance features
SOC2_COMPLIANCE_MODE=false
GDPR_COMPLIANCE_MODE=false
PCI_COMPLIANCE_MODE=false

# =============================================================================
# SECURITY HEADERS
# =============================================================================

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'

# Additional security headers
HSTS_MAX_AGE=31536000
REFERRER_POLICY=strict-origin-when-cross-origin

# =============================================================================
# INPUT VALIDATION
# =============================================================================

# Maximum input sizes (bytes)
MAX_CITY_NAME_LENGTH=100
MAX_QUERY_LENGTH=1000
MAX_REQUEST_SIZE=1048576

# =============================================================================
# SESSION SECURITY
# =============================================================================

# Session timeout (milliseconds)
SESSION_TIMEOUT=3600000

# Maximum concurrent sessions per IP
MAX_SESSIONS_PER_IP=10

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Security log level
SECURITY_LOG_LEVEL=info

# Enable structured logging
STRUCTURED_LOGGING_ENABLED=true

# Log format (json, structured, or cef)
AUDIT_LOG_FORMAT=json

# =============================================================================
# DEVELOPMENT/TESTING
# =============================================================================

# Disable security in development (NOT for production!)
SECURITY_DISABLED=false

# Enable security testing mode
SECURITY_TESTING_MODE=false

# Mock security responses for testing
MOCK_SECURITY_RESPONSES=false
