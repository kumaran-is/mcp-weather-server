# MCP Weather Server Environment Configuration
# Copy this file to .env and update the values as needed

# ===========================================
# Open-Meteo API Configuration
# ===========================================
# Base URL for Open-Meteo API (no API key required)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Geocoding API URL for city name to coordinates conversion
GEOCODING_API_URL=https://geocoding-api.open-meteo.com/v1

# ===========================================
# MCP Server Configuration
# ===========================================
# Transport type: 'stdio' for local AI assistants, 'http' for remote clients
MCP_TRANSPORT=stdio

# HTTP server port (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080

# MCP protocol version (should match client expectations)
MCP_PROTOCOL_VERSION=2025-06-18

# ===========================================
# Environment Settings
# ===========================================
# Application environment: 'development', 'production', 'test'
NODE_ENV=development

# ===========================================
# Security Configuration
# ===========================================
# Comma-separated list of allowed origins for CORS (HTTP transport only)
# Use '*' for development, specific domains for production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# Logging Configuration
# ===========================================
# Log level: 'fatal', 'error', 'warn', 'info', 'debug', 'trace'
LOG_LEVEL=debug

# ===========================================
# Performance & Timeout Settings
# ===========================================
# API request timeout in milliseconds
API_TIMEOUT=5000

# HTTP server timeout in milliseconds
HTTP_TIMEOUT=30000

# Number of API retry attempts
API_RETRIES=3

# Delay between retry attempts in milliseconds
API_RETRY_DELAY=1000

# ===========================================
# Session Management (HTTP Transport)
# ===========================================
# Session timeout in milliseconds (1 hour = 3600000)
SESSION_TIMEOUT=3600000

# Maximum number of concurrent sessions
MAX_SESSIONS=100

# ===========================================
# WebSocket Configuration (Optional)
# ===========================================
# WebSocket port (only used when MCP_TRANSPORT=websocket)
MCP_WS_PORT=8081

# Enable secure WebSocket connections (wss://)
MCP_WS_SECURE=false

# ===========================================
# Development & Testing
# ===========================================
# Enable debug mode for additional logging
DEBUG=false

# Enable request/response logging for API calls
LOG_API_REQUESTS=true

# ===========================================
# Docker & Deployment
# ===========================================
# Container port mapping (for Docker deployment)
CONTAINER_PORT=8080

# Health check endpoint path
HEALTH_CHECK_PATH=/health

# ===========================================
# Optional: External Service URLs
# ===========================================
# Custom weather API endpoint (if using a different provider)
# WEATHER_API_URL=

# Custom geocoding service URL
# GEOCODING_SERVICE_URL=

# ===========================================
# Optional: Monitoring & Metrics
# ===========================================
# Enable Prometheus metrics endpoint
# METRICS_ENABLED=false

# Metrics collection interval in milliseconds
# METRICS_INTERVAL=60000

# ===========================================
# Optional: Database Configuration
# ===========================================
# If you add caching or persistence features
# DATABASE_URL=
# REDIS_URL=

# ===========================================
# Notes:
# ===========================================
# 1. Never commit the actual .env file to version control
# 2. Use strong, unique values for any secrets or tokens
# 3. Adjust timeouts based on your network conditions
# 4. In production, use specific origins instead of wildcards
# 5. Monitor resource usage and adjust MAX_SESSIONS accordingly
# 6. Consider using environment-specific .env files (.env.production, etc.)
